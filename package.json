{
	"name": "tauri2-svelte5-shadcn",
	"private": true,
	"version": "2.0.0",
	"description": "A simple desktop application template combining Tauri 2 with Svelte 5 and shadcn-svelte with a basic ci/cd implemented.",
	"author": {
		"name": "Alysonhower Veras Vieira",
		"email": "contato@alysonhower.dev"
	},
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"tauri": "tauri",
		"test:unit": "vitest run",
		"test:watch": "vitest",
		"test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
		"test:check": "npm run check && npm run lint",
		"test": "npm run test:check && npm run test:unit && npm run test:rust"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@lucide/svelte": "^1.17.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tauri-apps/cli": "^2.11.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@tsconfig/svelte": "^5.0.8",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"jsdom": "^29.1.1",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.53.11",
		"svelte-check": "^4.4.5",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^8.0.0",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.2.1",
		"@tauri-apps/api": "^2.11.0",
		"@types/node": "^25.5.0",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.1"
	}
}
